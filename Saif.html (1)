<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Shopping Store</title>

<style>
body{
    margin:0;
    font-family:Arial;
    background:#f2f2f2;
}

header{
    background:#ff6600;
    color:white;
    text-align:center;
    padding:15px;
    font-size:30px;
    font-weight:bold;
}

.container{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:20px;
    padding:20px;
}

.product{
    background:white;
    width:220px;
    border-radius:10px;
    overflow:hidden;
    box-shadow:0 2px 8px rgba(0,0,0,0.2);
}

.product img{
    width:100%;
    height:180px;
    object-fit:cover;
}

.product-info{
    padding:15px;
    text-align:center;
}

.price{
    color:green;
    font-size:22px;
    margin:10px 0;
}

button{
    background:#ff6600;
    color:white;
    border:none;
    padding:10px 15px;
    border-radius:5px;
    cursor:pointer;
    margin-top:5px;
}

button:hover{
    background:#cc5200;
}

.payment{
    background:white;
    margin:20px;
    padding:20px;
    border-radius:10px;
    text-align:center;
    box-shadow:0 2px 8px rgba(0,0,0,0.2);
}

footer{
    background:#222;
    color:white;
    text-align:center;
    padding:10px;
    margin-top:20px;
}
</style>
</head>

<body>

<header>
🛍 My Shopping Store
</header>

<div class="container">

<div class="product">
    <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff" alt="">
    <div class="product-info">
        <h2>Running Shoes</h2>
        <div class="price">₹1200</div>
        <button onclick="buy('Running Shoes')">Buy Now</button>
    </div>
</div>

<div class="product">
    <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30" alt="">
    <div class="product-info">
        <h2>Smart Watch</h2>
        <div class="price">₹1800</div>
        <button onclick="buy('Smart Watch')">Buy Now</button>
    </div>
</div>

<div class="product">
    <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9" alt="">
    <div class="product-info">
        <h2>Mobile Phone</h2>
        <div class="price">₹9000</div>
        <button onclick="buy('Mobile Phone')">Buy Now</button>
    </div>
</div>

</div>

<div class="payment">
    <h2>💳 Payment Details</h2>
    <p>Send payment to this number:</p>
    <h1>8083282514</h1>
    <p>After payment, contact the shop owner.</p>
</div>

<footer>
Produced by Anubhav Kumar
</footer>

<script>
function buy(item){
    alert("You selected " + item);
}
</script>

</body>
</html>